POSTGRES_DB=healthapp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

AUTH_JWT_ISSUER=HealthApp.Backend
AUTH_JWT_AUDIENCE=HealthApp.Mobile
AUTH_JWT_SIGNING_KEY=some-secret-jwt-key-health-app

AUTH_GOOGLE_ALLOWED_CLIENT_ID_0=google-id-for-auth
AUTH_YANDEX_CLIENT_ID=yandex-od-for-auth
AUTH_YANDEX_CLIENT_SECRET=yandex-secret-key-for-auth

EMAIL_MODE=Smtp
EMAIL_FROM_ADDRESS=healthtrackerregister@gmail.com
EMAIL_FROM_NAME=HealthTrack
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_ENABLE_SSL=true
EMAIL_SMTP_USERNAME=healthtrackerregister@gmail.com
EMAIL_SMTP_PASSWORD=ТВОЙ_APP_PASSWORD

WEB_API_BASE_URL=/api
WEB_PORT=80
